{
  "name": "lingolint",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "The structural i18n auditor that fills the gaps without breaking the shape.",
  "license": "MIT",
  "author": "FriquetLuca",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FriquetLuca/lingolint.git"
  },
  "bugs": {
    "url": "https://github.com/FriquetLuca/lingolint/issues"
  },
  "homepage": "https://github.com/FriquetLuca/lingolint#readme",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx,json,css,md}\" --log-level silent"
  },
  "dependencies": {
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "^19.1.0-rc.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
